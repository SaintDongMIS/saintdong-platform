# COMMEET 同步：台灣上班日 週一至週五 08:30、14:30（容器需 TZ=Asia/Taipei）
30 8,14 * * 1-5 echo "=== $(date '+%Y-%m-%dT%H:%M:%S%z') ===" >> /var/log/commeet-sync.log 2>&1 && curl -s -w "\nHTTP_CODE:%{http_code}\n" -X POST http://127.0.0.1:3000/api/commeet/sync -H "Content-Type: application/json" -d '{}' >> /var/log/commeet-sync.log 2>&1
